{
  "name": "shadow-ide",
  "private": true,
  "version": "0.84.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/tauri-wrapper.cjs dev",
    "dev:native": "cargo run --manifest-path native/Cargo.toml -p shadow-editor",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "build:native": "cargo build --manifest-path native/Cargo.toml --release -p shadow-editor",
    "check:native": "cargo check --manifest-path native/Cargo.toml --workspace",
    "lint": "eslint .",
    "preview": "vite preview",
    "prune:rust-targets": "node scripts/prune-rust-targets.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "tauri": "node scripts/tauri-wrapper.cjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "monaco-editor": "^0.47.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
