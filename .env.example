# ShadowIDE Environment Variables

# WebSocket server port (default: 9000)
# SHADOW_WS_PORT=9000

# Rust log level (default: info)
# RUST_LOG=info

# Tauri dev server host (set automatically by Tauri CLI)
# TAURI_DEV_HOST=

# Signing keys for Tauri updater (set in CI secrets)
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
